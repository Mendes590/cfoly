# Database — SQLite for local dev (file path), PostgreSQL for production
DATABASE_URL="file:./dev.db"
# PostgreSQL example: DATABASE_URL="postgresql://user:password@localhost:5432/cfoly"

# JWT
JWT_SECRET="change-this-to-a-long-random-string-in-production"
JWT_EXPIRES_IN="7d"

# Server
PORT=3001

# Frontend URL (for CORS)
FRONTEND_URL="http://localhost:5173"
